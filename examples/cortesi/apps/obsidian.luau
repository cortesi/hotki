local a = hotki.actions
local STAY = { stay = true }

return function(menu: MenuBuilder)
    menu:submenu("shift+cmd+j", "obsidian", function(app_menu)
        app_menu:submenu("c", "content", function(content)
            content:submenu("i", "insert", function(insert)
                insert:bind("a", "attachment", a.relay("ctrl+shift+cmd+6"))
                insert:bind("c", "code", a.relay("ctrl+shift+cmd+7"))
                insert:bind("f", "footnote", a.relay("ctrl+shift+cmd+8"))
                insert:bind("l", "link", a.relay("ctrl+shift+cmd+9"))
            end)
            content:submenu("t", "table", function(tbl)
                tbl:bind("n", "new", a.relay("ctrl+shift+cmd+y"), STAY)
                tbl:bind("h", "column left", a.relay("ctrl+shift+cmd+u"), STAY)
                tbl:bind("l", "column right", a.relay("ctrl+shift+cmd+i"), STAY)
                tbl:bind("j", "row above", a.relay("ctrl+shift+cmd+o"), STAY)
                tbl:bind("k", "row below", a.relay("ctrl+shift+cmd+p"), STAY)
            end)
        end)
        app_menu:submenu("f", "file", function(file)
            file:bind("f", "show in finder", a.relay("ctrl+shift+cmd+4"))
            file:bind("n", "rename", a.relay("ctrl+shift+cmd+5"))
        end)
        app_menu:submenu("s", "split", function(split)
            split:bind("l", "right", a.relay("ctrl+shift+cmd+2"))
            split:bind("j", "down", a.relay("ctrl+shift+cmd+1"))
        end)
    end)
end
